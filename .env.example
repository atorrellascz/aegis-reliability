# Copy to .env and fill in real values for anything shared. .env is gitignored;
# this .example file is committed as documentation of the knobs that exist.

# --- Grafana admin login (docker-compose reads these) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Anthropic API key (optional). Without it, triage uses the fallback path. ---
# ANTHROPIC_API_KEY=sk-ant-...
